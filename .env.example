# ==========================================
# CLAWSEUM - Environment Configuration
# Copy to .env and adjust values per env.
# ==========================================

# ---- Core ----
ENVIRONMENT=development
COMPOSE_PROJECT_NAME=clawseum
NODE_ENV=production
LOG_LEVEL=INFO

# ---- Database (Postgres 15) ----
POSTGRES_DB=clawseum
POSTGRES_USER=clawseum
POSTGRES_PASSWORD=clawseum_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://clawseum:clawseum_dev_password@postgres:5432/clawseum

# ---- Redis (cache + pub/sub) ----
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- Backend services ----
# FastAPI/ASGI module path for each service.
GATEWAY_APP_MODULE=main:app
ARENA_APP_MODULE=main:app
FEED_APP_MODULE=main:app

# Turn on hot reload in development (0/1)
BACKEND_RELOAD=0

# Security / auth
JWT_SECRET=change-me-super-secret
OPENCLAW_SIGNING_SECRET=change-me-signing-secret

# API policy
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
API_RATE_LIMIT_PER_MINUTE=120

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WS_BASE_URL=ws://localhost/ws

# ---- Reverse proxy ----
NGINX_PORT=80

# ---- Setup / migrations ----
MIGRATION_SERVICE=backend-gateway
MIGRATION_CMD=python -m alembic upgrade head

# ---- Seed data ----
SEED_AGENT_COUNT=24
SEED_MATCH_COUNT=72
SEED_OUTPUT_DIR=data/seed
# Optional custom seed command executed in backend-gateway container
# SEED_CMD=python -m app.seed --agents 24 --matches 72
SEED_PUSH_TO_API=0
SEED_API_URL=http://localhost:8000/admin/seed

# ---- Deploy script behavior ----
DEPLOY_SEED=0

# ---- Optional deployment metadata ----
# DEPLOY_TARGET=fly|railway|render
# APP_DOMAIN=clawseum.example.com

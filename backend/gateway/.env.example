# CLAWSEUM Gateway API Configuration
# Copy this file to .env and fill in your values

# Required: Application Security
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# Required: Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/clawseum

# Application Settings
APP_NAME=CLAWSEUM Gateway API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# JWT Settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS Settings
CORS_ORIGINS=http://localhost:3000,https://clawseum.io
CORS_ALLOW_CREDENTIALS=true

# Database Pool
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# CLAWSEUM - Coolify Production Environment
# ==========================================
# Copy these values to Coolify resource environment variables.
# Update placeholders marked with <...> with values from Coolify resources.

# ---- Core ----
ENVIRONMENT=production
NODE_ENV=production
LOG_LEVEL=INFO

# ---- Database (Coolify PostgreSQL Resource) ----
# Copy these from your Coolify PostgreSQL resource:
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
# Or construct from:
POSTGRES_DB=<coolify-provided>
POSTGRES_USER=<coolify-provided>
POSTGRES_PASSWORD=<coolify-provided>
POSTGRES_HOST=<coolify-provided>
POSTGRES_PORT=5432

# ---- Redis (Coolify Redis Resource) ----
# Copy from your Coolify Redis resource:
# REDIS_URL=redis://<user>:<password>@<host>:<port>/0
# Or construct from:
REDIS_HOST=<coolify-provided>
REDIS_PORT=6379
REDIS_PASSWORD=<coolify-provided>

# ---- Backend services ----
# FastAPI/ASGI module path for each service.
GATEWAY_APP_MODULE=main:app
ARENA_APP_MODULE=main:app
FEED_APP_MODULE=main:app

# Turn off hot reload in production
BACKEND_RELOAD=0

# Security / auth (Generate strong random values)
JWT_SECRET=<generate-strong-secret-min-32-chars>
OPENCLAW_SIGNING_SECRET=<generate-strong-secret-min-32-chars>

# API policy
CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>,https://<your-gateway-domain>
API_RATE_LIMIT_PER_MINUTE=120

# ---- Frontend ----
FRONTEND_PORT=3000
# These point to your Coolify backend domains:
NEXT_PUBLIC_API_BASE_URL=https://<your-gateway-domain>/api
NEXT_PUBLIC_WS_BASE_URL=wss://<your-feed-domain>/ws

# ---- Feed Service WebSocket Settings ----
REDIS_PUBSUB_CHANNEL=clawseum:feed:events
WS_HEARTBEAT_INTERVAL_SECONDS=25
WS_HEARTBEAT_TIMEOUT_SECONDS=10

# ---- Setup / migrations ----
MIGRATION_SERVICE=backend-gateway
MIGRATION_CMD=python -m alembic upgrade head

# ---- Seed data (optional, for initial setup) ----
SEED_AGENT_COUNT=24
SEED_MATCH_COUNT=72
SEED_OUTPUT_DIR=data/seed
SEED_PUSH_TO_API=0
SEED_API_URL=https://<your-gateway-domain>/admin/seed

# ---- Deploy script behavior ----
DEPLOY_SEED=0

# ---- Coolify-specific ----
# These are automatically set by Coolify, but shown here for reference:
# SERVICE_FQDN_GATEWAY=<auto-generated>
# SERVICE_FQDN_ARENA=<auto-generated>
# SERVICE_FQDN_FEED=<auto-generated>
# SERVICE_FQDN_FRONTEND=<auto-generated>
